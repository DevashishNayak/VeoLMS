generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) URL for migrations — set DIRECT_URL locally / DATABASE_URL_UNPOOLED on Vercel
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  INSTRUCTOR
  ADMIN
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

/// How the course is delivered (drives student-facing labels & expectations).
enum CourseDeliveryType {
  /// Watch anytime — classic online / Udemy-style
  SELF_PACED
  /// Scheduled live sessions (Zoom / cohort)
  LIVE
  /// In-person / classroom
  OFFLINE
}

/// Lesson primary content kind (VIDEO can be YouTube and/or self-hosted URL).
enum LessonType {
  VIDEO
  TEXT
  PDF
}

/// Where lesson / trailer video bytes (or embeds) come from.
enum VideoProvider {
  YOUTUBE
  VIMEO
  /// Direct file URL (Vercel Blob, CDN, mp4/webm/HLS).
  FILE
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  passwordHash   String
  name           String
  /// Public instructor bio (shown on instructor + course pages)
  bio            String?          @db.Text
  role           Role             @default(STUDENT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  enrollments    Enrollment[]
  payments       Payment[]
  lessonProgress LessonProgress[]
  courses        Course[]         @relation("InstructorCourses")
  reviews        CourseReview[]
}

/// Nested categories for catalog + breadcrumbs (e.g. Development → Web Development).
model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  Category[] @relation("CategoryTree")
  courses   Course[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([parentId])
  @@index([slug])
}

model Course {
  id               String              @id @default(cuid())
  title            String
  slug             String              @unique
  /// Short pitch for cards / hero (Udemy-style subtitle)
  subtitle         String              @default("") @db.VarChar(200)
  /// Full course description (Description section)
  description      String              @db.Text
  thumbnail        String              @db.Text
  /// Bullet list shown as “What you’ll learn”
  learningOutcomes String[]            @default([])
  /// Bullet list shown as “Requirements”
  requirements     String[]            @default([])
  priceInPaise     Int
  featured         Boolean             @default(false)
  published        Boolean             @default(true)
  deliveryType     CourseDeliveryType  @default(SELF_PACED)
  trailerProvider  VideoProvider?
  trailerSrc       String?             @db.Text
  categoryId       String?
  category         Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  instructorId     String
  instructor       User                @relation("InstructorCourses", fields: [instructorId], references: [id])
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  sections         Section[]
  enrollments      Enrollment[]
  payments         Payment[]
  reviews          CourseReview[]

  @@index([slug])
  @@index([featured])
  @@index([instructorId])
  @@index([deliveryType])
  @@index([categoryId])
}

model CourseReview {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  /// 1–5 stars
  rating    Int
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@index([rating])
}

model Section {
  id        String   @id @default(cuid())
  title     String
  order     Int
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model Lesson {
  id            String         @id @default(cuid())
  title         String
  description   String?        @db.Text
  type          LessonType     @default(VIDEO)
  videoProvider VideoProvider?
  videoSrc      String?        @db.Text
  content       String?        @db.Text
  pdfUrl        String?        @db.Text
  duration      Int            @default(0)
  order         Int
  isPreview     Boolean        @default(false)
  sectionId     String
  section       Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress      LessonProgress[]
  resources     LessonResource[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([sectionId])
  @@index([type])
  @@index([videoProvider])
}

model LessonResource {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title     String
  url       String   @db.Text
  mimeType  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([lessonId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id             String   @id @default(cuid())
  userId         String
  lessonId       String
  watchedSeconds Int      @default(0)
  completed      Boolean  @default(false)
  lastWatchedAt  DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
}

model Payment {
  id                String        @id @default(cuid())
  userId            String
  courseId          String
  razorpayOrderId   String        @unique
  razorpayPaymentId String?       @unique
  razorpaySignature String?
  amountInPaise     Int
  status            PaymentStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  course            Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
}
