# Database (required)
# Local: use local Postgres from `npx prisma dev`
# Production/Staging: Neon connection strings from Vercel / Neon console
DATABASE_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"
# Unpooled URL for Prisma migrations (same as DATABASE_URL for local)
DIRECT_URL="postgres://postgres:postgres@localhost:51214/template1?sslmode=disable"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Razorpay Test Mode — https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="xxxxxxxx"
# Webhook signing secret (Dashboard → Webhooks). Falls back to KEY_SECRET if empty.
RAZORPAY_WEBHOOK_SECRET=""

# Vercel Blob (optional — uploads; paste HTTPS URLs still work without it)
BLOB_READ_WRITE_TOKEN=""
# Signed media delivery (/api/media) uses AUTH_SECRET for HMAC temporary URLs.

# --- Email OTP (pick one) ----------------------------------------------------
# Preferred without a custom domain: Gmail SMTP
# 1. Google Account → Security → 2-Step Verification ON
# 2. App passwords → create one for "Mail"
# 3. Paste the 16-character password below (spaces optional)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
GMAIL_FROM_NAME="VeoLMS"

# Resend — use after you verify your own domain (https://resend.com)
# Without a domain, Resend only sends to your Resend account email.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="VeoLMS <onboarding@resend.dev>"

